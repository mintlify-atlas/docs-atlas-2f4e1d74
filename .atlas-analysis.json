  "keyFeatures": [
    "Modular architecture inspired by Angular with Modules, Controllers, and Providers",
    "Built-in dependency injection container",
    "First-class TypeScript support with full JavaScript compatibility",
    "Microservices support (TCP, Redis, MQTT, NATS, RabbitMQ, Kafka, gRPC)",
    "WebSocket gateways with Socket.io and ws adapters",
    "Middleware, Guards, Interceptors, and Pipes as composable building blocks",
    "Platform-agnostic: supports Express and Fastify",
    "Interactive REPL for inspecting the application graph",
    "Built-in testing utilities with NestJS Testing module",
    "GraphQL support via @nestjs/graphql"
  ],
